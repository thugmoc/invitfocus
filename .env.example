# INVITEFOCUS BETA — Variables d'environnement
# Copie ce fichier en ".env" et remplis les valeurs

# Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXX

# Airtable (https://airtable.com/account → Personal Access Token)
AIRTABLE_TOKEN=pat_XXXXXXXXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Google Drive (fichier JSON depuis Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_DRIVE_FOLDER_ID=XXXXXXXXXX

# Slack (facultatif — pour les alertes)
SLACK_WEBHOOK=https://hooks.slack.com/services/XXXXXXXXXX
